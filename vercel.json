{
  "version": 2,
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/anticheat",
      "destination": "/anticheat.html"
    },
    {
      "source": "/check",
      "destination": "/check.html"
    },
    {
      "source": "/rules",
      "destination": "/rules.html"
    },
    {
      "source": "/profile",
      "destination": "/profile.html"
    },
    {
      "source": "/admin-panel",
      "destination": "/admin-panel.html"
    },
    {
      "source": "/tickets",
      "destination": "/tickets.html"
    },
    {
      "source": "/quotas",
      "destination": "/quotas.html"
    },
    {
      "source": "/api/steam/:path*",
      "destination": "/api/steam"
    },
    {
      "source": "/api/fear",
      "destination": "/api/fear.js"
    },
    {
      "source": "/api/player",
      "destination": "/api/player.js"
    },
    {
      "source": "/api/reports",
      "destination": "/api/reports.js"
    },
    {
      "source": "/api/uma",
      "destination": "/api/uma.js"
    }
  ],
  "functions": {
    "api/fear.js": {
      "maxDuration": 30
    },
    "api/player.js": {
      "maxDuration": 30
    },
    "api/reports.js": {
      "maxDuration": 30
    },
    "api/steam.js": {
      "maxDuration": 30
    },
    "api/uma.js": {
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}